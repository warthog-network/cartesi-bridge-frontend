---
// Minimal product header
---
<header class="bridge-header">
  <h1>WART Bridge</h1>
  <p class="bridge-sub">Lock WART · claim wWART · execute voucher</p>
</header>

<style>
  .bridge-header {
    text-align: center;
    padding: 1rem 0.75rem 0.5rem;
  }
  .bridge-header h1 {
    margin: 0;
    font-size: clamp(1.35rem, 4vw, 1.75rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #fff;
  }
  .bridge-sub {
    font-size: 0.8rem;
    opacity: 0.65;
    margin: 0.3rem 0 0;
    color: #ccc;
  }
</style>
