---
// src/pages/index.astro
import Header from '../components/Header.astro';
import DepositBox from '../components/DepositBox.astro';
import WalletIsland from '../components/WalletIsland.jsx';
import RatioCalculator from '../components/RatioCalculator.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>WLIQ — Warthog × Cartesi Bridge</title>
  </head>
  <body>
    <main class="container app-main">
      <Header />
      <WalletIsland client:load />
      <DepositBox />
      <details class="app-extras">
        <summary>Ratio calculator</summary>
        <RatioCalculator client:load />
      </details>
    </main>
  </body>
</html>

<style is:global>
  .app-main {
    padding-bottom: 2.5rem;
  }
  .app-extras {
    max-width: 40rem;
    margin: 0.5rem auto 1.5rem;
    padding: 0.65rem 0.9rem;
    border-radius: 12px;
    border: 1px solid #333;
    background: rgba(0, 0, 0, 0.25);
    color: #ccc;
    font-size: 0.85rem;
  }
  .app-extras summary {
    cursor: pointer;
    color: #00ffcc;
    font-weight: 600;
    list-style: none;
  }
  .app-extras summary::-webkit-details-marker {
    display: none;
  }
  .app-extras summary::before {
    content: '▸ ';
    opacity: 0.7;
  }
  .app-extras[open] summary::before {
    content: '▾ ';
  }
  .app-extras[open] {
    padding-bottom: 1rem;
  }
</style>
